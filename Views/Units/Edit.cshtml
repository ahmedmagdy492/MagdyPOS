@model Unit

<div class="card">
    <div class="card-header">
        <h2 class="card-title">تعديل وحدة</h2>
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group" style="margin-bottom:1rem;">
                <label asp-for="Name">الاسم</label>
                <input asp-for="Name" class="form-input" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group" style="margin-bottom:1rem;">
                <label asp-for="Symbol">الرمز</label>
                <input asp-for="Symbol" class="form-input" />
                <span asp-validation-for="Symbol" class="text-danger"></span>
            </div>

            <div class="form-group" style="margin-bottom:1rem;">
                <label asp-for="Notes">ملاحظات</label>
                <input asp-for="Notes" class="form-input" />
                <span asp-validation-for="Notes" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-modal-primary">حفظ</button>
            <a asp-action="Index" class="btn-modal-secondary">إلغاء</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
