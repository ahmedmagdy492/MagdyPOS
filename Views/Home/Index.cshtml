@{
    Layout = "_MarketingLayout";
    ViewData["MetaDescription"] = "برنامج كاشير للمطاعم والكافيهات في مصر يعمل بدون إنترنت. مبيعات، مخزون خامات، مصروفات، تقارير، حضور وانصراف. مناسب للمشاريع الصغيرة والمتوسطة.";
}

<section class="mkt-hero">
    <div class="mkt-container mkt-hero__inner">
        <div>
            <div class="mkt-badge">مخصص للكافيهات والمطاعم الصغيرة — يعمل Offline</div>
            <h1 class="mkt-hero__title">برنامج كاشير بسيط وسريع — بدون إنترنت</h1>
            <p class="mkt-hero__subtitle">
                بيع سريع، خصم خامات تلقائي، مصروفات ومشتريات، تقارير يومية، وإيراد (المبيعات - المصروفات) — كل شيء بالعربي.
            </p>

            <div class="mkt-hero__actions">
                <a class="mkt-btn mkt-btn--primary" href="#contact">اطلب تجربة / عرض سعر</a>
                <a class="mkt-btn" href="#features">شوف المميزات</a>
            </div>

            <div class="mkt-hero__meta">
                <div><strong>المكان:</strong> الإسكندرية / مصر</div>
                <div><strong>التشغيل:</strong> Windows + SQLite</div>
                <div><strong>الدعم:</strong> تركيب + تدريب + صيانة</div>
            </div>
        </div>

        <div class="mkt-card mkt-card--screen">
            <div class="mkt-card__title">لقطة سريعة</div>
            <ul class="mkt-list">
                <li>نقطة بيع (POS) سريعة</li>
                <li>مخزون خامات + تنبيهات نقص</li>
                <li>مصروفات + مشتريات مرتبطة بخامة</li>
                <li>ملخص اليوم + تصدير Excel (CSV)</li>
                <li>حضور وانصراف + تقرير أسبوعي</li>
            </ul>
        </div>
    </div>
</section>

<section id="features" class="mkt-section">
    <div class="mkt-container">
        <h2 class="mkt-h2">المميزات</h2>
        <div class="mkt-grid">
            <div class="mkt-card">
                <div class="mkt-card__title">المبيعات</div>
                <ul class="mkt-list">
                    <li>نقطة بيع سهلة وسريعة</li>
                    <li>خصم وملاحظات + بقشيش</li>
                    <li>عرض الطلبات والتفاصيل</li>
                </ul>
            </div>
            <div class="mkt-card">
                <div class="mkt-card__title">المخزون والخامات</div>
                <ul class="mkt-list">
                    <li>إدارة خامات وحدّ تنبيه</li>
                    <li>خصم خامات تلقائياً عند البيع</li>
                    <li>سجل حركات المخزون</li>
                </ul>
            </div>
            <div class="mkt-card">
                <div class="mkt-card__title">المصروفات والمشتريات</div>
                <ul class="mkt-list">
                    <li>تسجيل مصروفات يومية</li>
                    <li>مشتريات مرتبطة بخامة ترفع المخزون</li>
                    <li>تقارير الإيراد</li>
                </ul>
            </div>
            <div class="mkt-card">
                <div class="mkt-card__title">التقارير</div>
                <ul class="mkt-list">
                    <li>ملخص اليوم</li>
                    <li>تصدير Excel (CSV)</li>
                    <li>تقرير الإيراد (مبيعات - مصروفات)</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<section id="pricing" class="mkt-section mkt-section--alt">
    <div class="mkt-container">
        <h2 class="mkt-h2">الأسعار (Low → Mid)</h2>
        <p class="mkt-muted">الأسعار تختلف حسب عدد الأجهزة والطابعة والتجهيز. هذه أمثلة شائعة في السوق.</p>

        <div class="mkt-grid">
            <div class="mkt-card">
                <div class="mkt-card__title">باقة اقتصادية</div>
                <div class="mkt-price">من 1500 إلى 3000 جنيه</div>
                <ul class="mkt-list">
                    <li>تركيب + إعداد أولي</li>
                    <li>تدريب سريع</li>
                    <li>دعم شهري اختياري</li>
                </ul>
            </div>
            <div class="mkt-card">
                <div class="mkt-card__title">باقة متوسطة</div>
                <div class="mkt-price">من 4000 إلى 8000 جنيه</div>
                <ul class="mkt-list">
                    <li>إعداد كامل + تخصيص بسيط</li>
                    <li>متابعة ودعم أقوى</li>
                    <li>مناسب لعدد أجهزة أكثر</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<section id="faq" class="mkt-section">
    <div class="mkt-container">
        <h2 class="mkt-h2">أسئلة شائعة</h2>
        <div class="mkt-grid">
            <div class="mkt-card">
                <div class="mkt-card__title">هل البرنامج يحتاج إنترنت؟</div>
                <div class="mkt-muted">لا، يعمل بالكامل Offline على نفس الجهاز.</div>
            </div>
            <div class="mkt-card">
                <div class="mkt-card__title">هل يوجد نسخة تجريبية؟</div>
                <div class="mkt-muted">نعم، يمكن تجهيز تجربة على نفس جهازك أو عن بُعد.</div>
            </div>
            <div class="mkt-card">
                <div class="mkt-card__title">هل البيانات آمنة؟</div>
                <div class="mkt-muted">يمكن عمل نسخ احتياطي لقاعدة البيانات بسهولة (Backup/Restore).</div>
            </div>
            <div class="mkt-card">
                <div class="mkt-card__title">هل يدعم طباعة فواتير؟</div>
                <div class="mkt-muted">يمكن ربطه بالطابعة حسب نوع الطابعة (يتم تحديدها أثناء التركيب).</div>
            </div>
        </div>
    </div>
</section>

<section id="contact" class="mkt-section mkt-section--alt">
    <div class="mkt-container">
        <h2 class="mkt-h2">تواصل</h2>
        <p class="mkt-muted">اكتب رقم واتساب/مكالمة هنا (بدّل البيانات قبل النشر).</p>

        <div class="mkt-contact">
            <div class="mkt-card">
                <div class="mkt-card__title">واتساب</div>
                <div class="mkt-muted">+20 1X XXX XXXX</div>
            </div>
            <div class="mkt-card">
                <div class="mkt-card__title">العنوان</div>
                <div class="mkt-muted">الإسكندرية — تركيب داخل المحافظة</div>
            </div>
            <div class="mkt-card">
                <div class="mkt-card__title">تجربة</div>
                <div class="mkt-muted">تجهيز نسخة Demo + تدريب سريع للكاشير</div>
            </div>
        </div>
    </div>
</section>

