@{
    ViewData["Title"] = "غير مصرح";
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>غير مصرح | MagdyPOS</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body { display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; padding: 24px; }
        .box { max-width: 480px; text-align: center; background: #fff; border: 1px solid var(--border); border-radius: var(--radius); padding: 2rem; box-shadow: var(--shadow-md); }
        h1 { font-size: 1.35rem; margin: 0 0 0.75rem; }
        p { color: var(--text-gray); margin: 0 0 1.5rem; line-height: 1.6; }
        a { display: inline-block; padding: 0.65rem 1.25rem; background: var(--primary); color: #fff; border-radius: 10px; text-decoration: none; font-weight: 600; }
    </style>
</head>
<body>
    <div class="box">
        <h1>لا تملك صلاحية الوصول</h1>
        <p>هذه الصفحات مخصصة لمدير النظام فقط.</p>
        @if(User.Identity?.IsAuthenticated == true)
        {
            <a asp-controller="Pos" asp-action="Index">العودة للرئيسية</a>
        }
        else
        {
            <a href="/Login/Login">تسجيل الدخول</a>
        }
    </div>
</body>
</html>
