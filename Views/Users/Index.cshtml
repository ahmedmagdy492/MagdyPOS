@model IReadOnlyList<MagdyPOS.Models.UserListRowVm>
@using MagdyPOS.Authorization
@{
    ViewData["Title"] = "المستخدمون";
}

@if (TempData["UsersMessage"] is string ok && !string.IsNullOrWhiteSpace(ok))
{
    <div class="card" style="margin-bottom: 16px; border-color: var(--success); background: rgb(240, 253, 244);">
        <div class="card-body" style="padding: 12px 16px; color: var(--success); font-weight: 600;">@ok</div>
    </div>
}
@if (TempData["UsersError"] is string err && !string.IsNullOrWhiteSpace(err))
{
    <div class="card" style="margin-bottom: 16px; border-color: var(--error); background: rgb(254, 242, 242);">
        <div class="card-body" style="padding: 12px 16px; color: var(--error); font-weight: 600;">@err</div>
    </div>
}

<div class="admin-page-head">
    <div>
        <h1>إدارة المستخدمين</h1>
        <p>إنشاء المستخدمين وتعيين صلاحية مدير أو مبيعات.</p>
    </div>
    <button type="button" id="btnOpenAddUser" class="btn-admin-header">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
        إضافة مستخدم
    </button>
</div>

<div class="card">
    <div class="card-header">
        <h2 class="card-title">قائمة المستخدمين</h2>
    </div>
    <div class="card-body" style="padding: 0;">
        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>البريد</th>
                        <th>الاسم</th>
                        <th>الصلاحية</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        <tr data-id="@u.Id" data-email="@u.Email" data-fullname="@(u.FullName ?? "")" data-role="@(u.Roles.Contains("Admin", StringComparison.Ordinal) ? AppRoles.Admin : AppRoles.Sales)">
                            <td style="font-weight: 600;">@u.Email</td>
                            <td style="color: var(--text-gray);">@(u.FullName ?? "—")</td>
                            <td><span class="@(u.Roles.Contains("Admin", StringComparison.Ordinal) ? "badge success" : "badge-muted")">@u.Roles</span></td>
                            <td>
                                <div class="action-cell">
                                    <button type="button" class="action-btn action-btn-edit js-edit-user" title="تعديل" data-id="@u.Id"></button>
                                    @if(u.Roles.Contains("Sales", StringComparison.Ordinal)) {
                                        <button type="button" class="action-btn action-btn-delete js-delete-user" title="حذف" data-id="@u.Id" data-name="@u.Email"></button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="addUserModal" class="modal-overlay">
    <div class="modal-content">
        <div class="modal-content__head">
            <h2 class="modal-content__title">مستخدم جديد</h2>
            <button type="button" class="modal-close-btn" data-close-modal="addUserModal" aria-label="إغلاق"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></button>
        </div>
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="admin-modal-grid">
                <div class="full-row">
                    <label class="form-label" for="c_Email">البريد الإلكتروني (اسم الدخول)</label>
                    <input id="c_Email" name="Email" type="email" class="form-input" required />
                </div>
                <div class="full-row">
                    <label class="form-label" for="c_FullName">الاسم الظاهر</label>
                    <input id="c_FullName" name="FullName" type="text" class="form-input" />
                </div>
                <div>
                    <label class="form-label" for="c_Password">كلمة المرور</label>
                    <input id="c_Password" name="Password" type="password" class="form-input" required minlength="6" />
                </div>
                <div>
                    <label class="form-label" for="c_Role">الصلاحية</label>
                    <select id="c_Role" name="Role" class="form-select" required>
                        <option value="@AppRoles.Sales">مبيعات</option>
                        <option value="@AppRoles.Admin">مدير</option>
                    </select>
                </div>
            </div>
            <div class="admin-modal-actions">
                <button type="submit" class="btn-modal-primary">حفظ</button>
                <button type="button" class="btn-modal-secondary" data-close-modal="addUserModal">إلغاء</button>
            </div>
        </form>
    </div>
</div>

<div id="editUserModal" class="modal-overlay">
    <div class="modal-content">
        <div class="modal-content__head">
            <h2 class="modal-content__title">تعديل مستخدم</h2>
            <button type="button" class="modal-close-btn" data-close-modal="editUserModal" aria-label="إغلاق"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></button>
        </div>
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" id="edit_Id" />
            <div class="admin-modal-grid">
                <div class="full-row">
                    <label class="form-label" for="edit_Email">البريد الإلكتروني</label>
                    <input id="edit_Email" name="Email" type="email" class="form-input" required />
                </div>
                <div class="full-row">
                    <label class="form-label" for="edit_FullName">الاسم الظاهر</label>
                    <input id="edit_FullName" name="FullName" type="text" class="form-input" />
                </div>
                <div>
                    <label class="form-label" for="edit_Role">الصلاحية</label>
                    <select id="edit_Role" name="Role" class="form-select" required>
                        <option value="@AppRoles.Sales">مبيعات</option>
                        <option value="@AppRoles.Admin">مدير</option>
                    </select>
                </div>
                <div>
                    <label class="form-label" for="edit_NewPassword">كلمة مرور جديدة (اختياري)</label>
                    <input id="edit_NewPassword" name="NewPassword" type="password" class="form-input" minlength="6" />
                </div>
            </div>
            <div class="admin-modal-actions">
                <button type="submit" class="btn-modal-primary">حفظ التعديلات</button>
                <button type="button" class="btn-modal-secondary" data-close-modal="editUserModal">إلغاء</button>
            </div>
        </form>
    </div>
</div>

<div id="deleteUserModal" class="modal-overlay">
    <div class="modal-content modal-narrow">
        <div class="text-center">
            <div class="delete-modal-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--error)" stroke-width="2"><path d="M3 6h18"></path><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
            </div>
            <h2 class="modal-content__title" style="width: 100%; text-align: center; margin-bottom: 0.5rem;">حذف المستخدم</h2>
            <p style="color: var(--text-gray); margin: 0 0 1.5rem;">هل أنت متأكد من حذف <span id="deleteUserName" style="font-weight: 600; color: var(--text-dark);"></span>؟</p>
            <form asp-action="Delete" method="post" id="deleteUserForm" style="margin: 0;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="delete_Id" />
                <div class="admin-modal-actions">
                    <button type="submit" class="btn-modal-danger">حذف</button>
                    <button type="button" class="btn-modal-secondary" data-close-modal="deleteUserModal">إلغاء</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
(function () {
    var editSvg = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>';
    var delSvg = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>';
    document.querySelectorAll('.js-edit-user').forEach(function (b) { b.innerHTML = editSvg; });
    document.querySelectorAll('.js-delete-user').forEach(function (b) { b.innerHTML = delSvg; });

    function openModal(id) { var el = document.getElementById(id); if (el) { el.classList.add('active'); document.body.style.overflow = 'hidden'; } }
    function closeModal(id) { var el = document.getElementById(id); if (el) { el.classList.remove('active'); document.body.style.overflow = ''; } }

    document.getElementById('btnOpenAddUser')?.addEventListener('click', function () {
        closeModal('editUserModal'); closeModal('deleteUserModal');
        openModal('addUserModal');
    });
    document.querySelectorAll('[data-close-modal]').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var id = btn.getAttribute('data-close-modal');
            if (id) closeModal(id);
        });
    });
    ['addUserModal', 'editUserModal', 'deleteUserModal'].forEach(function (mid) {
        document.getElementById(mid)?.addEventListener('click', function (e) {
            if (e.target === e.currentTarget) closeModal(mid);
        });
    });
    document.querySelectorAll('.modal-content').forEach(function (p) {
        p.addEventListener('click', function (e) { e.stopPropagation(); });
    });

    document.querySelectorAll('.js-edit-user').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var tr = btn.closest('tr');
            if (!tr) return;
            document.getElementById('edit_Id').value = tr.dataset.id || '';
            document.getElementById('edit_Email').value = tr.dataset.email || '';
            document.getElementById('edit_FullName').value = tr.dataset.fullname || '';
            document.getElementById('edit_Role').value = tr.dataset.role || '@(AppRoles.Sales)';
            document.getElementById('edit_NewPassword').value = '';
            closeModal('addUserModal'); closeModal('deleteUserModal');
            openModal('editUserModal');
        });
    });

    document.querySelectorAll('.js-delete-user').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var tr = btn.closest('tr');
            if (!tr) return;
            document.getElementById('delete_Id').value = tr.dataset.id || '';
            document.getElementById('deleteUserName').textContent = btn.getAttribute('data-name') || '';
            closeModal('addUserModal'); closeModal('editUserModal');
            openModal('deleteUserModal');
        });
    });
})();
</script>
