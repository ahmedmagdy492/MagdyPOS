@model IEnumerable<Expense>

<div class="admin-page-head">
    <div>
        <h1>المصروفات</h1>
        <p>تسجيل وإدارة المصروفات (اختياري: ربط المصروف بخامة ليزيد المخزون).</p>
    </div>
    <div style="display:flex;gap:0.5rem;align-items:center;">
        <a asp-action="Create" class="btn-admin-header">إضافة مصروف</a>
    </div>

@{
    var q = Context.Request.Query;
    int pageNo = 1;
    int pageSize = 20;
    if (!string.IsNullOrEmpty(q["pageNo"])) int.TryParse(q["pageNo"], out pageNo);
    if (!string.IsNullOrEmpty(q["pageSize"])) int.TryParse(q["pageSize"], out pageSize);
    if (pageNo < 1) pageNo = 1;
    if (pageSize < 1) pageSize = 20;

    var from = q["from"].ToString();
    var to = q["to"].ToString();
    var queryText = q["q"].ToString();

    int totalCount = 0;
    if (ViewBag.TotalCount != null)
    {
        int.TryParse(ViewBag.TotalCount.ToString(), out totalCount);
    }

    var modelCount = Model?.Count() ?? 0;
    int totalPages;
    if (totalCount > 0)
    {
        totalPages = (int)Math.Ceiling(totalCount / (double)pageSize);
    }
    else
    {
        totalPages = (modelCount == pageSize) ? pageNo + 1 : pageNo;
    }
}
</div>

<div class="card">
    <div class="card-header">
        <h2 class="card-title">قائمة المصروفات</h2>
        <p style="color:red">@(ViewBag.DateFilterError)</p>

        <form method="get" style="display:flex;gap:0.5rem;align-items:end;flex-wrap:wrap;margin-top:0.5rem;">
            <div class="date-filter">
                <label style="color:var(--text-gray);font-size:0.9rem;margin-right:0.25rem;">من</label>
                <input name="from" type="date" class="form-control" value="@(ViewBag.From ?? from)" />
            </div>
            <div class="date-filter">
                <label style="color:var(--text-gray);font-size:0.9rem;margin-right:0.25rem;">إلى</label>
                <input name="to" type="date" class="form-control" value="@(ViewBag.To ?? to)" />
            </div>
            <div class="date-filter" style="min-width:260px;">
                <label style="color:var(--text-gray);font-size:0.9rem;margin-right:0.25rem;">بحث</label>
                <input name="q" type="text" class="form-control" value="@queryText" placeholder="عنوان / ملاحظات / خامة" />
            </div>
            <button type="submit" class="btn-admin-header">تصفية</button>
        </form>
    </div>

    <div class="card-body" style="padding: 0;">
        <div class="table-wrapper">
            <table>
                <thead>
                <tr>
                    <th>#</th>
                    <th>التاريخ</th>
                    <th>العنوان</th>
                    <th>القيمة</th>
                    <th>الخامة (اختياري)</th>
                    <th>كمية الخامة</th>
                    <th>الإجراءات</th>
                </tr>
                </thead>
                <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" style="padding: 1rem; color: var(--text-gray); text-align:center;">لا توجد مصروفات.</td>
                    </tr>
                }
                else
                {
                    foreach (var e in Model)
                    {
                        <tr>
                            <td style="font-weight:600;">@e.Id</td>
                            <td style="color:var(--text-gray);">@e.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@e.Title</td>
                            <td style="font-weight:700;">@e.Amount.ToString("0.00") ج.م</td>
                            <td style="color:var(--text-gray);">@(e.Material == null ? "-" : $"{e.Material.Name} ({e.Material.Id})")</td>
                            <td style="color:var(--text-gray);">@(e.MaterialQuantity.HasValue ? e.MaterialQuantity.Value.ToString("0.###") : "-")</td>
                            <td>
                                <div class="action-cell">
                                    <a asp-action="Details" asp-route-id="@e.Id" class="action-btn action-btn-edit" title="عرض" style="display:inline-flex;align-items:center;justify-content:center;text-decoration:none;">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8S1 12 1 12z"></path>
                                            <circle cx="12" cy="12" r="3"></circle>
                                        </svg>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@e.Id" class="action-btn action-btn-edit" title="تعديل" style="display:inline-flex;align-items:center;justify-content:center;text-decoration:none;">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M12 20h9"></path>
                                            <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"></path>
                                        </svg>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@e.Id" class="action-btn action-btn-delete" title="حذف" style="display:inline-flex;align-items:center;justify-content:center;text-decoration:none;">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M3 6h18"></path>
                                            <path d="M8 6V4h8v2"></path>
                                            <path d="M19 6l-1 14H6L5 6"></path>
                                            <path d="M10 11v6"></path>
                                            <path d="M14 11v6"></path>
                                        </svg>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card-footer" style="display:flex;align-items:center;justify-content:space-between;padding:0.75rem 1rem;">
        @{
            var maxPagesToShow = 5;
            var startPage = Math.Max(1, pageNo - 2);
            var endPage = Math.Min(totalPages, startPage + maxPagesToShow - 1);
            if (endPage - startPage < maxPagesToShow - 1)
            {
                startPage = Math.Max(1, endPage - maxPagesToShow + 1);
            }
        }

        <div style="display:flex;align-items:center;gap:0.5rem;">
            <form method="get" style="display:flex;align-items:center;gap:0.5rem;">
                <input type="hidden" name="from" value="@from" />
                <input type="hidden" name="to" value="@to" />
                <input type="hidden" name="q" value="@queryText" />
                <input type="hidden" name="pageNo" value="1" />
                <label style="color:var(--text-gray);">عرض</label>
                <select name="pageSize" onchange="this.form.submit()" style="padding:0.25rem;">
                    <option value="10" selected="@(pageSize == 10 ? "selected" : "")">10</option>
                    <option value="20" selected="@(pageSize == 20 ? "selected" : "")">20</option>
                    <option value="50" selected="@(pageSize == 50 ? "selected" : "")">50</option>
                    <option value="100" selected="@(pageSize == 100 ? "selected" : "")">100</option>
                </select>
            </form>
        </div>

        <div style="display:flex;align-items:center;gap:0.25rem;">
            <a asp-action="Index" asp-route-pageNo="@(pageNo - 1)" asp-route-pageSize="@pageSize" asp-route-from="@from" asp-route-to="@to" asp-route-q="@queryText"
               class="btn" style="pointer-events:@(pageNo <= 1 ? "none" : "auto");opacity:@(pageNo <= 1 ? "0.5" : "1");">&laquo; السابق</a>

            @for (int p = startPage; p <= endPage; p++)
            {
                <a asp-action="Index" asp-route-pageNo="@p" asp-route-pageSize="@pageSize" asp-route-from="@from" asp-route-to="@to" asp-route-q="@queryText"
                   class="btn" style="font-weight:@(p == pageNo ? "700" : "400");">@p</a>
            }

            <a asp-action="Index" asp-route-pageNo="@(pageNo + 1)" asp-route-pageSize="@pageSize" asp-route-from="@from" asp-route-to="@to" asp-route-q="@queryText"
               class="btn" style="pointer-events:@(pageNo >= totalPages ? "none" : "auto");opacity:@(pageNo >= totalPages ? "0.5" : "1");">التالي &raquo;</a>
        </div>

        <div style="color:var(--text-gray);">
            @if (totalCount > 0)
            {
                <span>إظهار @(((pageNo - 1) * pageSize) + 1)-@Math.Min(pageNo * pageSize, totalCount) من @totalCount</span>
            }
            else
            {
                <span>إظهار @modelCount من النتائج</span>
            }
        </div>
    </div>
</div>

