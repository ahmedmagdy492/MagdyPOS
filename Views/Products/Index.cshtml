@model IEnumerable<ProductListItemViewModel>
@{
    var units = ViewBag.Units as IEnumerable<Unit> ?? Enumerable.Empty<Unit>();
    var materials = ViewBag.Materials as IEnumerable<Material> ?? Enumerable.Empty<Material>();
}

<form style="display:none">
    @Html.AntiForgeryToken()
</form>

<div class="admin-page-head">
    <div>
        <h1>إدارة المنتجات</h1>
        <p>عرض وإضافة وتعديل المنتجات وربطها بالخامات.</p>
    </div>
    <button type="button" id="btnOpenAddProduct" class="btn-admin-header">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
        </svg>
        إضافة منتج
    </button>
</div>

<div class="card">
    <div class="card-header">
        <h2 class="card-title">قائمة المنتجات</h2>
    </div>
    <div class="card-body" style="padding: 0;">
        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>اسم المنتج</th>
                        <th>الكود</th>
                        <th>الوحدة</th>
                        <th>السعر</th>
                        <th>عدد الخامات</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
                <tbody id="productsTableBody">
                @if (!Model.Any())
                {
                    <tr data-empty-state="products">
                        <td colspan="6" style="padding: 1rem; color: var(--text-gray); text-align:center;">
                            لا توجد منتجات بعد.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var p in Model)
                    {
                        <tr data-id="@p.Id"
                            data-name="@p.Name"
                            data-unit-id="@p.UnitId"
                            data-unit-name="@p.UnitName"
                            data-unit-symbol="@p.UnitSymbol"
                            data-price="@p.Price"
                            data-material-ids="@string.Join(",", p.MaterialIds)"
                            data-material-quantities="@string.Join(",", p.MaterialQuantities.Select(x => x.ToString(System.Globalization.CultureInfo.InvariantCulture)))"
                            data-materials-count="@p.MaterialsCount">
                            <td style="font-weight: 600;">@p.Name</td>
                            <td style="color: var(--text-gray);">@p.Id</td>
                            <td>@p.UnitName</td>
                            <td style="font-weight: 600;">@p.Price.ToString("0.00") ج.م</td>
                            <td style="color: var(--text-gray);">@p.MaterialsCount</td>
                            <td>
                                <div class="action-cell">
                                    <button type="button" class="action-btn action-btn-edit" title="تعديل">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                                        </svg>
                                    </button>
                                    <button type="button" class="action-btn action-btn-delete" title="حذف">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <polyline points="3 6 5 6 21 6"></polyline>
                                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                        </svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="addProductModal" class="modal-overlay">
    <div class="modal-content">
        <div class="modal-content__head">
            <h2 class="modal-content__title">إضافة منتج</h2>
            <button type="button" class="modal-close-btn" data-close-modal="addProductModal" aria-label="إغلاق">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>
        <form id="addProductForm">
            <div class="admin-modal-grid">
                <div>
                    <label class="form-label">اسم المنتج <span style="color: var(--error);">*</span></label>
                    <input type="text" id="productName" class="form-input" required />
                </div>
                <div>
                    <label class="form-label">الكود <span style="color: var(--error);">*</span></label>
                    <input type="text" id="productId" class="form-input" placeholder="مثال: PR-001" required />
                </div>
                <div>
                    <label class="form-label">الوحدة <span style="color: var(--error);">*</span></label>
                    <select id="productUnit" class="form-select" required>
                        <option value="">اختر الوحدة</option>
                        @foreach (var u in units)
                        {
                            <option value="@u.Id">@u.Name</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="form-label">السعر <span style="color: var(--error);">*</span></label>
                    <input type="number" id="productPrice" class="form-input" min="0" step="0.01" required />
                </div>
                <div class="full-row">
                    <label class="form-label">الخامات (اختيار متعدد)</label>
                    <select id="productMaterials" class="form-select" multiple size="6">
                        @foreach (var m in materials)
                        {
                            <option value="@m.Id">@m.Name (@m.Id)</option>
                        }
                    </select>
                    <p style="color: var(--text-gray); font-size: 12px; margin-top: 6px;">يمكنك اختيار أكثر من خامة لنفس المنتج.</p>
                </div>
                <div class="full-row">
                    <label class="form-label">كمية كل خامة في المنتج</label>
                    <div id="productMaterialQtyList" class="admin-modal-grid"></div>
                </div>
            </div>
            <div class="admin-modal-actions">
                <button type="submit" class="btn-modal-primary">حفظ</button>
                <button type="button" class="btn-modal-secondary" data-close-modal="addProductModal">إلغاء</button>
            </div>
        </form>
    </div>
</div>

<div id="editProductModal" class="modal-overlay">
    <div class="modal-content">
        <div class="modal-content__head">
            <h2 class="modal-content__title">تعديل منتج</h2>
            <button type="button" class="modal-close-btn" data-close-modal="editProductModal" aria-label="إغلاق">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>
        <form id="editProductForm">
            <div class="admin-modal-grid">
                <div>
                    <label class="form-label">اسم المنتج <span style="color: var(--error);">*</span></label>
                    <input type="text" id="editProductName" class="form-input" required />
                </div>
                <div>
                    <label class="form-label">الكود</label>
                    <input type="text" id="editProductId" class="form-input" readonly />
                </div>
                <div>
                    <label class="form-label">الوحدة <span style="color: var(--error);">*</span></label>
                    <select id="editProductUnit" class="form-select" required>
                        @foreach (var u in units)
                        {
                            <option value="@u.Id">@u.Name</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="form-label">السعر <span style="color: var(--error);">*</span></label>
                    <input type="number" id="editProductPrice" class="form-input" min="0" step="0.01" required />
                </div>
                <div class="full-row">
                    <label class="form-label">الخامات (اختيار متعدد)</label>
                    <select id="editProductMaterials" class="form-select" multiple size="6">
                        @foreach (var m in materials)
                        {
                            <option value="@m.Id">@m.Name (@m.Id)</option>
                        }
                    </select>
                </div>
                <div class="full-row">
                    <label class="form-label">كمية كل خامة في المنتج</label>
                    <div id="editProductMaterialQtyList" class="admin-modal-grid"></div>
                </div>
            </div>
            <div class="admin-modal-actions">
                <button type="submit" class="btn-modal-primary">حفظ التعديلات</button>
                <button type="button" class="btn-modal-secondary" data-close-modal="editProductModal">إلغاء</button>
            </div>
        </form>
    </div>
</div>

<div id="deleteProductModal" class="modal-overlay">
    <div class="modal-content modal-narrow">
        <div class="text-center">
            <div class="delete-modal-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--error)" stroke-width="2">
                    <path d="M3 6h18"></path>
                    <path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path>
                    <path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path>
                    <line x1="10" y1="11" x2="10" y2="17"></line>
                    <line x1="14" y1="11" x2="14" y2="17"></line>
                </svg>
            </div>
            <h2 class="modal-content__title" style="width: 100%; text-align: center; margin-bottom: 0.5rem;">حذف المنتج</h2>
            <p style="color: var(--text-gray); margin: 0 0 1.5rem;">هل أنت متأكد من حذف <span id="deleteProductName" style="font-weight: 600; color: var(--text-dark);"></span>؟</p>
            <div class="admin-modal-actions">
                <button type="button" id="btnConfirmDeleteProduct" class="btn-modal-danger">حذف</button>
                <button type="button" class="btn-modal-secondary" data-close-modal="deleteProductModal">إلغاء</button>
            </div>
        </div>
    </div>
</div>

<script src="~/js/admin-crud-pages.js" asp-append-version="true"></script>

